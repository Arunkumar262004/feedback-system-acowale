# Server
PORT=5000
NODE_ENV=development

# Database (Render Postgres connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/acowale_crm
DATABASE_SSL=false

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Seed admin (created automatically on first migrate if not present)
ADMIN_EMAIL=admin@acowale.com
ADMIN_PASSWORD=ChangeMe123!

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
